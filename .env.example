# AI 201 Week 2 Demo — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ────────────────────────────────────────────────────────────────

# Your OpenRouter API key.
# Sign up free at: https://openrouter.ai
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Optional ────────────────────────────────────────────────────────────────

# OpenRouter model to use.
# Default: meta-llama/llama-3.1-8b-instruct:free
# Note: for tool-calling demos, models that reliably follow tool schemas work best.
# Good free options with strong tool-call support:
#   meta-llama/llama-3.1-8b-instruct:free
#   mistralai/mistral-7b-instruct:free
# Full list: https://openrouter.ai/models?q=free
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
