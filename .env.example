# AI 201 Week 2 Demo — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ────────────────────────────────────────────────────────────────

# Your OpenRouter API key.
# Sign up free at: https://openrouter.ai
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Optional ────────────────────────────────────────────────────────────────

# OpenRouter model to use.
# Default: openai/gpt-oss-20b:free
# Note: for tool-calling demos, models that reliably follow tool schemas work best.
# Good free options with strong tool-call support (verified 2026-06):
#   openai/gpt-oss-20b:free       (used in the Week 1 demo)
#   z-ai/glm-4.5-air:free
#   nvidia/nemotron-nano-9b-v2:free
# Full list: https://openrouter.ai/models?q=free
# OPENROUTER_MODEL=openai/gpt-oss-20b:free
